# BRND_OS environment example.
# Copy to .env.local for local development and fill real values outside git.
# Do not commit real secrets.

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
AUTH_SECRET="replace-with-random-base64-secret"
NEXTAUTH_SECRET=""
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ADMIN_PASSWORD=""
ALLOWED_FIDS=""
RATE_LIMIT_ENABLED="true"

# -----------------------------------------------------------------------------
# Turso / libSQL
# -----------------------------------------------------------------------------
TURSO_DATABASE_URL="libsql://example-org-example.turso.io"
TURSO_AUTH_TOKEN=""
TURSO_ALLOWLIST_DATABASE_URL="libsql://example-org-allowlist.turso.io"
TURSO_ALLOWLIST_AUTH_TOKEN=""

# -----------------------------------------------------------------------------
# Postgres indexer (Season 2 read-side)
# INDEXER_DATABASE_URL must include an explicit schema query param when enabled.
# Example: postgresql://user:pass@host:5432/db?sslmode=require&schema=production
# -----------------------------------------------------------------------------
INDEXER_DATABASE_URL=""
INDEXER_DISABLED="true"
INDEXER_API_KEY=""
INDEXER_SOURCE="ponder-stories-in-motion-v8"
BACKEND_API_BASE_URL="https://brnd-v2-backend-production.up.railway.app"

# -----------------------------------------------------------------------------
# MySQL legacy (Season 1 / fallback)
# -----------------------------------------------------------------------------
MYSQL_DATABASE_URL=""
MYSQL_DATABASE_URL_WRITE=""
MYSQL_SHADOW_DATABASE_URL=""
MYSQL_DISABLED="true"
READONLY_DATABASE_URL=""

# -----------------------------------------------------------------------------
# Redis / Upstash
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
REDIS_DEBUG="false"

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
GEMINI_API_KEY=""
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# Web3 / Base / WalletConnect
# -----------------------------------------------------------------------------
BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"
NEXT_PUBLIC_BASE_RPC_URLS=""
NEXT_PUBLIC_MAINNET_RPC_URL="https://ethereum.publicnode.com"
NEXT_PUBLIC_REOWN_PROJECT_ID=""
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
DISABLE_ONCHAIN_GATING="false"
NEXT_PUBLIC_DISABLE_ONCHAIN_GATING="false"

# -----------------------------------------------------------------------------
# Farcaster / Neynar
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FARCASTER_RPC_URL="https://mainnet.optimism.io"
NEXT_PUBLIC_FARCASTER_RELAY_URL="https://relay.farcaster.xyz"
NEYNAR_API_KEY=""
NEYNAR_TIMEOUT_MS="4000"

# -----------------------------------------------------------------------------
# Images / storage
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_IMAGES_API_KEY=""
PINATA_GATEWAY_TOKEN=""

# -----------------------------------------------------------------------------
# Google Sheets snapshots/imports
# -----------------------------------------------------------------------------
BRANDS_SHEET_ID=""
BRANDS_SHEET_GID="0"

# -----------------------------------------------------------------------------
# Deployment / build metadata
# Normally provided by the hosting platform or npm; do not set manually unless
# debugging a platform-specific path.
# -----------------------------------------------------------------------------
NETLIFY=""
NODE_ENV="development"
COMMIT_REF=""
CONTEXT=""
REVIEW_ID=""
DEPLOY_PRIME_URL=""
npm_lifecycle_event=""
